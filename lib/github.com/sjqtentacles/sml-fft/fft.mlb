(* MLB for the sml-fft library: the vendored sml-complex core plus the FFT
 * sources. Consumers reference this file.
 *
 * The dependency .mlb is brought in WITHOUT a `local` wrapper so that
 * consumers (the test suite, examples) can `open Complex` alongside Fft. *)
$(SML_LIB)/basis/basis.mlb
../sml-complex/sources.mlb
fft.sig
fft.sml
